{
  "name": "syncpeer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:cli",
    "test:cli": "npm run build:cli && node packages/cli/dist/main.js --help",
    "download:syncthing": "node scripts/download-syncthing.mjs",
    "test:local": "node scripts/test-local.ts",
    "test:local:keep": "node scripts/test-local.ts --keep",
    "test:local-discovery": "node --experimental-strip-types scripts/test-node-local-discovery.ts",
    "test:local-discovery:once": "node --experimental-strip-types scripts/test-node-local-discovery.ts --once",
    "test:local-discovery:self": "node --experimental-strip-types scripts/test-node-local-discovery-selftest.ts",
    "build": "npm run build:cli && npm run build:app && npm run build:tauri",
    "build:cli": "npm run build -w @syncpeer/cli",
    "build:app": "npm run build -w @syncpeer/app",
    "build:tauri": "npm run build -w @syncpeer/tauri-shell",
    "build:tauri:bundle": "npm run build:bundle -w @syncpeer/tauri-shell",
    "build:tauri:bundle:appimage": "npm run build:bundle:appimage -w @syncpeer/tauri-shell",
    "build:tauri:bundle:deb": "npm run build:bundle:deb -w @syncpeer/tauri-shell",
    "build:android:init": "npm run android:init -w @syncpeer/tauri-shell",
    "build:android": "npm run build:android:prod",
    "build:android:prod": "scripts/build-android-prod-with-secrets.sh",
    "build:android:dev": "npm run build:android:dev -w @syncpeer/tauri-shell && node scripts/copy-android-apk.mjs debug",
    "android:install:diagnose": "scripts/diagnose-android-install.sh dist/syncpeer-android-release-arm64-v8a.apk dev.syncpeer.app",
    "android:dev": "npm run android:dev -w @syncpeer/tauri-shell",
    "icons:generate": "npm run icons:generate -w @syncpeer/tauri-shell",
    "icons:ensure": "node scripts/ensure-tauri-icons.mjs",
    "icons:ensure:android": "node scripts/ensure-tauri-icons.mjs --android",
    "build:dev": "npm run build && npm run dev",
    "dev": "npm run dev -w @syncpeer/tauri-shell 2>&1 | tee output.log"
  }
}
