{
  "name": "syncpeer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:cli",
    "test:cli": "npm run build:core && npm run build:cli && node packages/cli/dist/main.js --help",
    "download:syncthing": "node scripts/download-syncthing.mjs",
    "test:local": "node scripts/test-local.mjs",
    "test:local:keep": "node scripts/test-local.mjs --keep",
    "build": "npm run build:core && npm run build:cli && npm run build:app && npm run build:tauri",
    "build:core": "npm run build -w @syncpeer/core",
    "build:cli": "npm run build -w @syncpeer/cli",
    "build:app": "npm run build -w @syncpeer/app",
    "build:tauri": "npm run build -w @syncpeer/tauri-shell",
    "build:android:init": "npm run android:init -w @syncpeer/tauri-shell",
    "build:android": "npm run build:android:prod",
    "build:android:prod": "scripts/build-android-prod-with-secrets.sh",
    "build:android:dev": "npm run build:android:dev -w @syncpeer/tauri-shell && node scripts/copy-android-apk.mjs debug",
    "android:install:diagnose": "scripts/diagnose-android-install.sh dist/syncpeer-android-release-arm64-v8a.apk dev.syncpeer.app",
    "android:dev": "npm run android:dev -w @syncpeer/tauri-shell",
    "build:dev": "npm run build && npm run dev",
    "dev": "npm run dev -w @syncpeer/tauri-shell 2>&1 | tee output.log"
  }
}
