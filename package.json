{
  "name": "syncpeer",
  "version": "0.1.0",
  "description": "Minimal BEP client for Syncthing (read-only)",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/main.ts",
    "test": "npm run test:cli",
    "test:cli": "npm run build && node dist/cli/main.js --help",
    "download:syncthing": "node scripts/download-syncthing.mjs",
    "test:local": "tsx scripts/test-local.ts",
    "test:local:keep": "tsx scripts/test-local.ts --keep"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
