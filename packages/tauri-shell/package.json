{
  "name": "@syncpeer/tauri-shell",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build --no-bundle",
    "build:bundle": "tauri build",
    "build:bundle:appimage": "tauri build --bundles appimage",
    "build:bundle:deb": "tauri build --bundles deb",
    "android:dev": "tauri android dev",
    "android:init": "tauri android init",
    "build:android:dev": "tauri android build --debug --apk --target aarch64",
    "build:android:prod": "tauri android build --apk --target aarch64",
    "build:android": "npm run build:android:prod"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  },
  "dependencies": {
    "@syncpeer/app": "0.0.0",
    "@tauri-apps/api": "^2.10.1"
  }
}
