{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main Syncpeer window.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:webview:allow-internal-toggle-devtools",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APPCACHE/syncpeer/files"
        },
        {
          "path": "$APPCACHE/syncpeer/files/**"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "file://*"
        }
      ]
    }
  ]
}
