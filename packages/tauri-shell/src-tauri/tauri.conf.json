{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Syncpeer",
  "version": "0.1.0",
  "identifier": "dev.syncpeer.app",
  "build": {
    "beforeBuildCommand": "npm install && npm run build -w @syncpeer/app",
    "beforeDevCommand": "npm run dev -w @syncpeer/app",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Syncpeer",
        "width": 800,
        "height": 600,
        "decorations": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "useLocalToolsDir": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
